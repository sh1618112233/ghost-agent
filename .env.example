# Ghost Agent - Environment Configuration
# Copy this file to ".env" and fill in your own values.
# NEVER commit your real .env file to Git.

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram chat ID or bot username to receive notifications
TELEGRAM_CHAT_ID="your_chat_id_here"

# Optional: SMTP credentials for the email outreach fallback
SMTP_EMAIL=your_email@example.com
SMTP_PASSWORD=your_email_app_password_here
